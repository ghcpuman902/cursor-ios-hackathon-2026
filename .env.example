# Copy to .env.local for local development:
#   cp .env.example .env.local
#
# Never commit .env.local or other .env.*.local files.

# ─── Male Translator™ ───────────────────────────────────────────────────────
# All vars are optional — defaults are tuned for maximum comedy.

# App branding (public)
NEXT_PUBLIC_APP_NAME=Male Translator™
NEXT_PUBLIC_APP_TAGLINE=Decoding grunts, shrugs, and three-word texts since forever

# Sarcasm dial: 1 (gentle) → 10 (nuclear honesty). Unlocks spicier translations at 8+.
NEXT_PUBLIC_SARCASM_LEVEL=7

# Append grunt annotations like *[exhales through nose]* to translations
NEXT_PUBLIC_GRUNT_MODE=false

# Fake "consulting the council" loading delay in milliseconds (0–5000)
NEXT_PUBLIC_TRANSLATION_DELAY_MS=800

# ─── AI audio (server-only) ─────────────────────────────────────────────────
# AI Gateway uses VERCEL_OIDC_TOKEN automatically on Vercel deployments.
# For local development, create a Gateway key:
# AI_GATEWAY_API_KEY=vck_...
# AI_GATEWAY_TEXT_MODEL=openai/gpt-5.6-sol
# AI_GATEWAY_TRANSCRIPTION_MODEL=openai/whisper-1
# AI_GATEWAY_SPEECH_MODEL=openai/tts-1
# AI_GATEWAY_MALE_SPEECH_VOICE=onyx
# AI_GATEWAY_FEMALE_SPEECH_VOICE=nova
# Optional: force one voice for both modes
# AI_GATEWAY_SPEECH_VOICE=alloy

# Optional: public site URL (used by some integrations)
# NEXT_PUBLIC_APP_URL=http://localhost:3000
